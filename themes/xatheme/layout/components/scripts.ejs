<!-- Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />



<!-- Theme scripts -->
<script src="<%- url_for('js/main.js') %>"></script>
<script src="<%- url_for('js/search.js') %>"></script>

<% if (is_post() && theme.features.toc !== false) { %>
<!-- TOC functionality -->
<script src="<%- url_for('js/toc.js') %>"></script>
<% } %>

<% if (config.mermaid && config.mermaid.enable) { %>
<!-- Mermaid diagrams -->
<script type="module">
  import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@<%= config.mermaid.version || "10.9.0" %>/dist/mermaid.esm.min.mjs';
  mermaid.initialize(JSON.parse('<%- JSON.stringify(config.mermaid.options || { startOnLoad: true }) %>'));
</script>
<% } %>